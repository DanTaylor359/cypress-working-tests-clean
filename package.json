{
  "name": "cypress-working-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome --headed --spec \"cypress/e2e/Account-Sign-In/Sign-In.cy.js\" && npm run report",
    "headless": "cypress run --browser chrome --headless",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json --reportDir cypress/reports",
    "report": "npm run report:merge && npm run report:generate && npm run open:report",
    "open:report": "sleep 2 && open -a \"Safari\" /Users/danieltaylor/cypress-working-tests/cypress/reports/report.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanTaylor359/cypress-working-tests.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DanTaylor359/cypress-working-tests/issues"
  },
  "homepage": "https://github.com/DanTaylor359/cypress-working-tests#readme",
  "description": "",
  "devDependencies": {
    "cypress": "^15.13.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
